{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "einhaender",
        "model": {
          "type": "minecraft:model",
          "model": "item/iron_sword/einhaender"
        }
      },
      {
        "when": "seax",
        "model": {
          "type": "minecraft:model",
          "model": "item/iron_sword/seax"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/iron_sword"
    }
  }
}